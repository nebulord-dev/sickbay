    "ink": "^6.8.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "open": "^11.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "ink-testing-library": "^4.0.0",
    "tsup": "catalog:",
