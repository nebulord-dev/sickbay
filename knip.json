{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["packages/*/src/index.ts"],
      "project": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx"]
    },
    "packages/*": {
      "entry": ["src/index.ts", "src/index.tsx"],
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": [
        "@nebulord/sickbay-core",
        "@nebulord/sickbay",
        "@nebulord/sickbay-web",
        "tsup",
        "eslint-config-prettier",
        "@testing-library/jest-dom",
        "@testing-library/react"
      ]
    }
  },
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/dist/**"
  ],
  "ignoreDependencies": [
    "@nebulord/sickbay-core",
    "@nebulord/sickbay",
    "@nebulord/sickbay-web",
    "tsup",
    "eslint-config-prettier",
    "@testing-library/jest-dom",
    "@testing-library/react"
  ]
}
