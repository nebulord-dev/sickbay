{
  "name": "sickbay-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "cli": "pnpm --filter @nebulord/sickbay dev",
    "web": "pnpm --filter @nebulord/sickbay-web dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:web": "pnpm --filter @nebulord/sickbay-web test",
    "test:web:ui": "pnpm --filter @nebulord/sickbay-web test:ui",
    "test:cli": "pnpm --filter @nebulord/sickbay test",
    "test:cli:ui": "pnpm --filter @nebulord/sickbay test:ui",
    "test:core": "pnpm --filter @nebulord/sickbay-core test",
    "test:core:ui": "pnpm --filter @nebulord/sickbay-core test:ui",
    "test:snapshots": "vitest run --config tests/snapshots/vitest.config.ts",
    "docs:dev": "pnpm --filter @nebulord/sickbay-docs docs:dev",
    "docs:build": "pnpm --filter @nebulord/sickbay-docs docs:build",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsup": "catalog:",
    "turbo": "^2.8.21",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "@types/minimatch": ">=3.0.5",
      "rollup": ">=4.59.0",
      "prismjs": ">=1.30.0",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5"
    }
  }
}
