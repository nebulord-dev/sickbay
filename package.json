{
  "name": "sickbay-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "cli": "pnpm --filter sickbay dev",
    "web": "pnpm --filter @nebulord/sickbay-web dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check:bundled-deps": "node scripts/check-bundled-deps.mjs",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:web": "pnpm --filter @nebulord/sickbay-web test",
    "test:web:ui": "pnpm --filter @nebulord/sickbay-web test:ui",
    "test:cli": "pnpm --filter sickbay test",
    "test:cli:ui": "pnpm --filter sickbay test:ui",
    "test:core": "pnpm --filter @nebulord/sickbay-core test",
    "test:core:ui": "pnpm --filter @nebulord/sickbay-core test:ui",
    "test:snapshots": "vitest run --config tests/snapshots/vitest.config.ts",
    "docs:dev": "pnpm --filter @nebulord/sickbay-docs docs:dev",
    "docs:build": "pnpm --filter @nebulord/sickbay-docs docs:build",
    "clean": "turbo run clean && rm -rf node_modules",
    "all-checks": "pnpm build && pnpm test && pnpm test:snapshots && pnpm lint && pnpm format && pnpm check:bundled-deps",
    "prepare": "husky"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "semantic-release": "^25.0.3",
    "tsup": "catalog:",
    "turbo": "^2.9.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "!(fixtures)/**/*.{ts,tsx,js,jsx,mjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "!(fixtures)/**/*.{css,html}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "@types/minimatch": ">=3.0.5",
      "rollup": ">=4.59.0",
      "prismjs": ">=1.30.0",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0"
    }
  }
}
