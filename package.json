{
  "name": "sickbay-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "cli": "pnpm --filter @sickbay/cli dev",
    "web": "pnpm --filter @sickbay/web dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:web": "pnpm --filter @sickbay/web test",
    "test:web:ui": "pnpm --filter @sickbay/web test:ui",
    "test:cli": "pnpm --filter @sickbay/cli test",
    "test:cli:ui": "pnpm --filter @sickbay/cli test:ui",
    "test:core": "pnpm --filter @sickbay/core",
    "test:core:ui": "pnpm --filter @sickbay/core test:ui",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tsup": "^8.5.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "@types/minimatch": ">=3.0.5",
      "rollup": ">=4.59.0",
      "prismjs": ">=1.30.0"
    }
  }
}
