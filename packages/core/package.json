{
  "name": "@nebulord/sickbay-core",
  "version": "1.2.0",
  "description": "Analysis engine for the Sickbay health check CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebulord-dev/sickbay"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "depcheck": "^1.4.7",
    "execa": "^9.6.1",
    "globby": "^16.2.0",
    "jscpd": "^4.0.8",
    "knip": "^6.1.0",
    "license-checker": "^25.0.1",
    "madge": "^8.0.0",
    "source-map-explorer": "^2.5.3"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
