{
  "name": "sickbay-core",
  "version": "1.3.0",
  "private": true,
  "description": "Analysis engine for the Sickbay health check CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebulord-dev/sickbay"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "depcheck": "^1.4.7",
    "execa": "^9.6.1",
    "globby": "^16.2.0",
    "jiti": "^2.6.1",
    "jscpd": "^4.0.9",
    "knip": "^6.4.1",
    "license-checker": "^25.0.1",
    "madge": "^8.0.0",
    "picomatch": "^4.0.4",
    "source-map-explorer": "^2.5.3"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.3",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
