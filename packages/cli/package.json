{
  "name": "@vitals/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "vitals": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@vitals/core": "workspace:*",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0",
    "dotenv": "^17.2.4",
    "ink": "^5.0.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "open": "^10.1.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
